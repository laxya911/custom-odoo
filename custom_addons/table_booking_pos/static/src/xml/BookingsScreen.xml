<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="table_booking_pos.BookingsScreen" owl="1">
        <div class="screen bookings-screen flex-grow-1 d-flex flex-column h-100 bg-view overflow-hidden">
            <!-- Header/Control Panel -->
            <div class="control-panel d-flex align-items-center p-3 border-bottom bg-white shadow-sm" style="min-height: 70px;">
                <div class="d-flex align-items-center flex-grow-1">
                    <button class="btn btn-lg btn-light border me-3 shadow-sm px-4" t-on-click="back">
                        <i class="fa fa-chevron-left me-2" />
                        <span>Tables</span>
                    </button>
                    <h2 class="m-0 fw-bold text-primary">Reservations Today</h2>
                </div>
                
                <div class="search-bar d-flex align-items-center bg-light rounded-pill px-3 py-1" style="width: 300px;">
                    <i class="fa fa-search text-muted me-2" />
                    <input type="text" class="form-control border-0 bg-transparent" placeholder="Search customer..." t-model="state.searchWord" />
                </div>
                
                <button class="btn btn-lg btn-primary ms-3 shadow-sm px-4 rounded-pill" t-on-click="loadBookings">
                    <i class="fa fa-refresh me-2" />
                    <span>Refresh</span>
                </button>
                
                <button class="btn btn-lg btn-success ms-2 shadow-sm px-4 rounded-pill" t-on-click="() => this.createNewBooking()">
                    <i class="fa fa-plus me-2" />
                    <span>New Booking</span>
                </button>
            </div>
            
            <!-- List View Content -->
            <div class="flex-grow-1 overflow-auto bg-view">
                <t t-if="state.isLoading">
                    <div class="d-flex flex-column align-items-center justify-content-center h-100 py-5">
                        <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status"></div>
                        <h4 class="text-muted">Loading reservations...</h4>
                    </div>
                </t>
                <t t-else="">
                    <t t-log="'Rendering bookings in screen:', state.bookings"/>
                    <div class="p-3">
                        <table class="table table-hover bg-white border rounded shadow-sm overflow-hidden mb-5">
                            <thead>
                                <tr class="text-uppercase text-dark fw-bold bg-light border-bottom">
                                    <th class="py-3 px-4">Ref</th>
                                    <th class="py-3">Customer</th>
                                    <th class="py-3">Phone</th>
                                    <th class="py-3">Email</th>
                                    <th class="py-3 text-center">Guests</th>
                                    <th class="py-3">Time</th>
                                    <th class="py-3">Tables</th>
                                    <th class="py-3">Status</th>
                                    <th class="py-3 text-end px-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="align-middle">
                                <t t-foreach="filteredBookings" t-as="booking" t-key="booking.id">
                                    <tr class="border-bottom hover-bg-light transition-base">
                                        <td class="py-3 px-4 fw-bold text-dark"><t t-esc="booking.name"/></td>
                                        <td class="py-3">
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-sm bg-primary-subtle text-primary rounded-circle me-2 d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px; font-size: 14px;">
                                                    <t t-esc="booking.customer_name[0]"/>
                                                </div>
                                                <t t-esc="booking.customer_name"/>
                                            </div>
                                        </td>
                                        <td class="py-3">
                                            <a t-attf-href="tel:{{booking.customer_phone}}" class="text-decoration-none text-primary fw-bold">
                                                <i class="fa fa-phone me-1"/> <t t-esc="booking.customer_phone"/>
                                            </a>
                                        </td>
                                        <td class="py-3">
                                            <a t-if="booking.customer_email" t-attf-href="mailto:{{booking.customer_email}}" class="text-decoration-none text-muted small">
                                                <i class="fa fa-envelope me-1"/> <t t-esc="booking.customer_email"/>
                                            </a>
                                            <span t-else="" class="text-muted opacity-50">-</span>
                                        </td>
                                        <td class="py-3 text-center">
                                            <span class="badge rounded-pill bg-light text-dark border px-3">
                                                <i class="fa fa-users me-1 text-secondary"/> <t t-esc="booking.party_size"/>
                                            </span>
                                        </td>
                                        <td class="py-3 text-primary fw-bold"><t t-esc="formatTime(booking.start_time)"/></td>
                                        <td class="py-3 text-muted"><t t-esc="booking.table_names or '-'"/></td>
                                        <td class="py-3">
                                            <span t-attf-class="badge rounded-pill px-3 py-2 {{ booking.status === 'confirmed' ? 'bg-primary' : booking.status === 'checked_in' ? 'bg-success' : booking.status === 'completed' ? 'bg-info text-white' : 'bg-secondary' }}">
                                                <t t-esc="getBookingStatus(booking.status)"/>
                                            </span>
                                        </td>
                                        <td class="py-3 text-end px-4">
                                            <t t-if="booking.status === 'confirmed'">
                                                <button class="btn btn-success btn-sm me-1 px-3 shadow-sm border-0" t-on-click="() => this.checkIn(booking.id)">Check-in</button>
                                                <button class="btn btn-outline-danger btn-sm px-3" t-on-click="() => this.noShow(booking.id)">No-show</button>
                                            </t>
                                            <t t-if="booking.status === 'checked_in'">
                                                <button class="btn btn-info btn-sm px-3 text-white shadow-sm border-0" t-on-click="() => this.actionComplete(booking.id)">Complete</button>
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                                <t t-if="!state.bookings.length">
                                    <tr>
                                        <td colspan="9" class="text-center py-5 text-muted">
                                            <div class="py-5">
                                                <i class="fa fa-calendar-o d-block mb-3" style="font-size: 80px; opacity: 0.1;" />
                                                <h4 class="fw-bold">No reservations found today</h4>
                                                <p>New bookings will appear here automatically.</p>
                                            </div>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>
