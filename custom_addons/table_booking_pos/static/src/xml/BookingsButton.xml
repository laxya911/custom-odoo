<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="table_booking_pos.BookingsButton" owl="1">
        <button class="btn btn-light border-0 d-flex align-items-center px-4 nav-link-custom" 
                t-att-class="{ 'active bg-view text-primary': isActive }"
                t-on-click.stop="onClick">
            <i class="fa fa-calendar-check-o me-2" role="img" aria-label="Bookings" title="Bookings" />
            <span class="fw-bold">Bookings</span>
        </button>
    </t>

    <t t-inherit="point_of_sale.Navbar" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('navbar-menu')]" position="inside">
            <BookingsButton t-if="pos.config.module_pos_restaurant" />
        </xpath>
    </t>
</templates>
