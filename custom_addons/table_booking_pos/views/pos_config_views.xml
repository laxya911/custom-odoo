<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="pos_config_view_form_inherit_table_booking" model="ir.ui.view">
            <field name="name">pos.config.form.inherit.table.booking</field>
            <field name="model">pos.config</field>
            <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@id='title']" position="after">
                    <div class="col-12 col-lg-6 o_setting_box" id="table_booking_setting">
                        <div class="o_setting_left_pane">
                            <field name="accept_table_bookings"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="accept_table_bookings"/>
                            <div class="text-muted">
                                Receive real-time table booking notifications and track status on floor plan.
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
