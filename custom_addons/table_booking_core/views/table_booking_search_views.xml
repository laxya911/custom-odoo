<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_table_booking_search" model="ir.ui.view">
        <field name="name">table.booking.search</field>
        <field name="model">table.booking</field>
        <field name="arch" type="xml">
            <search string="Table Bookings">
                <field name="name" string="Booking Ref"/>
                <field name="customer_name" string="Customer"/>
                <separator/>
                <filter string="Upcoming" name="upcoming"
                    domain="[('start_time','&gt;=', (datetime.datetime.combine(context_today(), datetime.time(0,0,0))))]"/>
                <filter string="Confirmed" name="confirmed"
                    domain="[('status','=','confirmed')]"/>
                <filter string="Checked In" name="checked_in"
                    domain="[('status','=','checked_in')]"/>
                <filter string="Completed" name="completed"
                    domain="[('status','=','completed')]"/>
                <filter string="Cancelled" name="cancelled"
                    domain="[('status','=','cancelled')]"/>
                <filter string="No Show" name="no_show"
                    domain="[('status','=','no_show')]"/>
            </search>
        </field>
    </record>
</odoo>
