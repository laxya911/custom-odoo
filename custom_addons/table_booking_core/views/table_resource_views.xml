<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_table_resource_form" model="ir.ui.view">
            <field name="name">table.resource.form</field>
            <field name="model">table.resource</field>
            <field name="arch" type="xml">
                <form string="Table Resource">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="capacity"/>
                            </group>
                            <group>
                                <field name="pos_table_id"/>
                                <field name="is_combinable"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_table_resource_tree" model="ir.ui.view">
            <field name="name">table.resource.tree</field>
            <field name="model">table.resource</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="name"/>
                    <field name="capacity"/>
                    <field name="pos_table_id"/>
                    <field name="is_combinable"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="action_table_resource" model="ir.actions.act_window">
            <field name="name">Booking Tables</field>
            <field name="res_model">table.resource</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
