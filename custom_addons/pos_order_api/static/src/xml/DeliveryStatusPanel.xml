<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_order_api.DeliveryStatusPanel" owl="1">
        <div class="delivery-status-panel d-flex flex-column gap-2 p-2 border rounded bg-light mt-2" t-if="props.order.is_api_order">
            <div class="d-flex justify-content-between align-items-center">
                <span class="fw-bold">Delivery Status:</span>
                <span class="badge rounded-pill" 
                      t-attf-class="{{ props.order.delivery_status === 'delivered' ? 'text-bg-success' : (props.order.delivery_status === 'cancelled' ? 'text-bg-danger' : 'text-bg-warning') }}">
                    <t t-esc="statusLabel"/>
                </span>
            </div>
            
            <div class="status-actions d-flex gap-1" t-if="nextStatus">
                <button class="btn btn-primary btn-sm flex-fill" t-on-click="() => this.updateStatus(this.nextStatus)">
                    <t t-esc="nextStatusLabel"/>
                </button>
                <button t-if="props.order.delivery_status === 'received'" 
                        class="btn btn-outline-danger btn-sm" 
                        t-on-click="() => this.updateStatus('cancelled')">
                    Cancel
                </button>
            </div>
            
            <div class="delivery-meta small text-muted" t-if="props.order.api_delivery_address">
                <i class="fa fa-map-marker me-1"/>
                <t t-esc="props.order.api_delivery_address"/>
            </div>
        </div>
    </t>
</templates>
